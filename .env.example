# =====================================================
# HƯỚNG DẪN: Copy file này thành .env rồi điền giá trị
#   cp .env.example .env
# =====================================================

# ---------------------------
# MySQL
# ---------------------------
# Đặt mật khẩu bất kỳ cho database, ví dụ: MyPassword@123
MYSQL_ROOT_PASSWORD=your_strong_password_here

# ---------------------------
# JWT
# ---------------------------
# Chuỗi bí mật để ký JWT token — phải dài ít nhất 32 ký tự
# Gợi ý tạo ngẫu nhiên: openssl rand -hex 32
JWT_SECRET=your-very-long-secret-key-for-jwt-signing-must-be-at-least-256-bits

# ---------------------------
# VNPay Sandbox
# ---------------------------
# Đăng ký tại https://sandbox.vnpayment.vn/apis/vnpay-demo/ để lấy thông tin
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret

# URL trả về sau khi thanh toán — thay YOUR_IP bằng IP máy chủ hoặc localhost
# Ví dụ local:  http://localhost:3000/payment/return
# Ví dụ server: http://192.168.1.100:3000/payment/return
VNPAY_RETURN_URL=http://localhost:3000/payment/return

# ---------------------------
# Server
# ---------------------------
# IP của máy chủ chạy Docker (dùng để build frontend)
# Dùng localhost nếu chạy trên máy local
SERVER_IP=localhost
